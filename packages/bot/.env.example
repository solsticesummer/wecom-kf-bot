# WeCom (企业微信) — all from the admin console at work.weixin.qq.com
# 我的企业 → 企业信息 → 企业ID
CORP_ID=ww1234567890abcdef
# 微信客服 → API → Secret (企业内部开发凭据)
KF_SECRET=your-kf-secret
# 微信客服 → API → 接收消息设置 → Token (you generate this; must match the console)
WECOM_TOKEN=your-random-token
# Same screen → EncodingAESKey (43 chars; you generate this; must match the console)
WECOM_AES_KEY=your-43-char-encoding-aes-key-goes-here-xx

# Aliyun 百炼 (DashScope) — from bailian.console.aliyun.com → API-KEY
DASHSCOPE_API_KEY=sk-...
# Model id — verify the exact id in 百炼 → 模型广场 (e.g. qwen-plus / qwen3.7-plus)
# QWEN_MODEL=qwen3.7-plus
# Reply creativity: 0 = 最稳定/偏复述, 越高越有创意/多样 (建议 0.4–0.8; default 0.6)
# QWEN_TEMPERATURE=0.6

# Secret for the staff-facing bug list at GET /bugs?token=...
# Leave unset to disable the endpoint entirely.
# ADMIN_TOKEN=pick-a-long-random-string

# Optional: greeting sent when a customer opens the chat
# WELCOME_MSG=您好！我是智能客服助手，很高兴为您服务，请问有什么可以帮您？

# Optional: the "转人工客服" menu re-offered after each bot answer, and the
# message sent when a customer taps it. All have sensible defaults in code.
# HUMAN_MENU_HEAD=没有解决您的问题？
# HUMAN_MENU_ITEM=转人工客服
# HUMAN_HANDOFF_REPLY=好的，正在为您转接人工客服，请稍候。

# Optional: per-customer rate limit (protects Qwen tokens from a spammer).
# Defaults: 15 messages per 60s per customer, then a one-time "slow down" notice.
# RATE_LIMIT_MAX=15
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_MSG=您发送得太频繁啦，请稍等一下再发送哦～

# Safety allowlist while testing: comma-separated kf account open_kfids the bot
# is allowed to answer. The 微信客服 callback is enterprise-wide, so set this to
# your TEST account's open_kfid so the bot can't answer the live 官方客服.
# Find open_kfids with:  node --env-file=.env scripts/list-kf.js
# Leave UNSET in production to answer every kf account.
# ALLOWED_KF_IDS=wkxxxxxxTESTxxxxxx

# --- Retrieval (Phase 1: hybrid vector + trigram + rerank) ---
# Postgres (with pgvector + pg_trgm). Local dev: postgres://<you>@localhost:5432/wecom
DATABASE_URL=postgres://user:pass@localhost:5432/wecom
# Embeddings + rerank are Model Studio (百炼) services and need a STANDARD DashScope
# key (sk-...) — NOT a Coding-Plan (sk-sp-...) key. If empty, generateReply() falls
# back to inlining the full FAQ.
MODELSTUDIO_API_KEY=sk-...
# EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_DIM=1024
# RERANK_API_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
# RERANK_MODEL=qwen3-rerank
# RETRIEVAL_TOP_K=5
# RETRIEVAL_CANDIDATES=20
# Near-duplicate suppression: two retrieved chunks with cosine >= this are treated as
# duplicates and the lower-ranked one is dropped (keeps top-k diverse). 0.92 keeps
# complementary same-topic chunks; lower it to be more aggressive.
# RETRIEVAL_DEDUP_SIM=0.92
# Where build-index.js finds the manual (.pdf) + whitepaper (.pptx) source docs
# KB_SOURCE_DIR=./knowledge/sources

# Optional overrides
# DATA_DIR=./data
# PORT=3000
