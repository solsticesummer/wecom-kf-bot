# Postgres for the knowledge store. Use a DEDICATED database so the dev tool
# never shares the live bot's data. (pgvector + pg_trgm are created automatically.)
KNOWLEDGE_DATABASE_URL=postgresql:///knowledge_dev

# DashScope embeddings need the STANDARD (sk-ws) Model Studio key.
# MODELSTUDIO_API_KEY is preferred; DASHSCOPE_API_KEY is the fallback.
MODELSTUDIO_API_KEY=sk-xxxxxxxx

# Optional overrides (defaults shown):
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_DIM=1024
# KNOWLEDGE_EMBEDDER=dashscope   # set to "fake" for offline (non-semantic) tests
