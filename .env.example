# WeCom (企业微信) — all from the admin console at work.weixin.qq.com
# 我的企业 → 企业信息 → 企业ID
CORP_ID=ww1234567890abcdef
# 微信客服 → API → Secret (企业内部开发凭据)
KF_SECRET=your-kf-secret
# 微信客服 → API → 接收消息设置 → Token (you generate this; must match the console)
WECOM_TOKEN=your-random-token
# Same screen → EncodingAESKey (43 chars; you generate this; must match the console)
WECOM_AES_KEY=your-43-char-encoding-aes-key-goes-here-xx

# Anthropic — from platform.claude.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: greeting sent when a customer opens the chat (skip to disable)
# WELCOME_MSG=您好！我是智能客服助手，请问有什么可以帮您？

# Optional overrides
# CLAUDE_MODEL=claude-opus-4-8
# DATA_DIR=./data
# PORT=3000
