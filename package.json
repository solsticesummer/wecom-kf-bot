{
  "name": "wecom-kf-bot-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo: TypeScript WeCom bot (packages/bot) + Python knowledge/MCP layer (packages/knowledge).",
  "workspaces": [
    "packages/bot"
  ],
  "scripts": {
    "build": "npm run build -w wecom-kf-bot",
    "typecheck": "npm run typecheck -w wecom-kf-bot",
    "test": "npm test -w wecom-kf-bot",
    "start": "npm start -w wecom-kf-bot",
    "dev": "npm run dev -w wecom-kf-bot",
    "demo": "npm run demo -w wecom-kf-bot",
    "chat": "npm run chat -w wecom-kf-bot",
    "migrate": "npm run migrate -w wecom-kf-bot",
    "index": "npm run index -w wecom-kf-bot",
    "list-kf": "npm run list-kf -w wecom-kf-bot"
  }
}
